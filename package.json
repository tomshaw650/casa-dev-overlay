{
  "name": "casa-dev-overlay",
  "version": "0.2.3",
  "description": "A local-dev overlay for GOV.UK CASA apps. Visualises the journey graph, inspects the JourneyContext, jumps to any waypoint, and auto-fills with reusable presets (compatible with spiderplan personas).",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./src/index.js",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "require": "./dist/index.cjs",
      "default": "./src/index.js"
    }
  },
  "files": [
    "src/**/*",
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "test": "node --test test/*.test.js",
    "test:cjs": "node test/cjs-smoke.cjs",
    "lint": "echo 'no lint configured yet' && exit 0",
    "prepublishOnly": "npm run build && npm test && npm run test:cjs"
  },
  "peerDependencies": {
    "@dwp/govuk-casa": ">=9 <10",
    "express": "^4.18.0 || ^5.0.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "esbuild": "0.24.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tomshaw650/casa-dev-overlay.git"
  },
  "bugs": {
    "url": "https://github.com/tomshaw650/casa-dev-overlay/issues"
  },
  "homepage": "https://github.com/tomshaw650/casa-dev-overlay#readme",
  "author": "Tom Shaw",
  "license": "MIT"
}
